# Local dev environment for the Stimulize Chatroom backend.
# Copy to `.env.local` and source before running `python dev_server.py`.

USE_MOCK_DYNAMO=true
USE_MOCK_RDS=true
USE_MOCK_LOBBY=true

JWT_SECRET=dev-secret
ADMIN_TOKEN=dev-admin-token

BEDROCK_REGION=us-east-2

# Dump full conversation rows (events + ticks + participants) to disk on
# every mutation, one JSON file per conversation. Tail with e.g.:
#   jq . backend/dev_dumps/conversations/<conversation_id>.json
# Set to empty to disable. dev_server.py defaults this to a path under
# backend/dev_dumps when not set.
DEV_DUMP_CONVERSATIONS_DIR=

# When USE_MOCK_RDS=false, the backend reads chatroom settings via the
# management API instead of Postgres directly. Set MGMT_API_URL to the
# deployed management API origin (no trailing slash) and MGMT_API_TOKEN
# to its bearer. Leave both empty to fall back to direct Postgres.
MGMT_API_URL=
MGMT_API_TOKEN=

# Local heartbeat thread (no ECS). When true, dev_server.py spawns a
# daemon thread that ticks active conversations in-process every
# HEARTBEAT_INTERVAL_SEC seconds.
TICK_HANDLER_LOCAL=true
HEARTBEAT_INTERVAL_SEC=5
